t matched. For multi-stack monorepos, join with ' + ' (e.g. 'Node.js / JavaScript + Python').\"\n43\t    },\n44\t    \"overview\": {\n45\t      \"$ref\": \"#/$defs/DualSection\",\n46\t      \"description\": \"High-level summary of what the project is and does.\"\n47\t    },\n48\t    \"tech_stack\": {\n49\t      \"type\": \"object\",\n50\t      \"description\": \"Breakdown of every language, framework, tool, and runtime detected in the project.\",\n51\t      \"required\": [\"technical\", \"layman\", \"entries\"],\n52\t      \"additionalProperties\": false,\n53\t      \"properties\": {\n54\t        \"technical\": { \"type\": \"string\", \"minLength\": 1, \"description\": \"Technical narrative of the full technology stack.\" },\n55\t        \"layman\": { \"type\": \"string\", \"minLength\": 1, \"description\": \"Plain-English explanation of the technology stack for a non-developer.\" },\n56\t        \"entries\": {\n57\t          \"type\": \"array\",\n58\t          \"minItems\": 1,\n59\t          \"description\": \"Individual stack entries, one per language/framework/tool.\",\n60\t          \"items\": {\n61\t            \"type\": \"object\",\n62\t            \"required\": [\"name\", \"role\", \"version\"],\n63\t            \"additionalProperties\": false,\n64\t            \"properties\": {\n65\t              \"name\":    { \"type\": \"string\", \"minLength\": 1, \"description\": \"Technology name, e.g. 'TypeScript'.\" },\n66\t              \"role\":    { \"type\": \"string\", \"minLength\": 1, \"description\": \"What this technology does, e.g. 'primary language'.\" },\n67\t              \"version\": { \"type\": \"string\", \"description\": \"Version string from manifest, or 'unknown' if not pinned.\" }\n68\t            }\n69\t          }\n70\t        }\n71\t      }\n72\t    },\n73\t    \"architecture\": {\n74\t      \"type\": \"object\",\n75\t      \"description\": \"Structural overview of how the project is organized and how its major parts connect.\",\n76\t      \"required\": [\"technical\", \"layman\", \"mermaid\"],\n77\t      \"additionalProperties\": false,\n78\t      \"properties\": {\n79\t        \"technical\": { \"type\": \"string\", \"minLength\": 1, \"description\": \"Technical narrative: layers, modules, data flows, service boundaries.\" },\n80\t        \"layman\":    { \"type\": \"string\", \"minLength\": 1, \"description\": \"Plain-English analogy of how the pieces fit together.\" },\n81\t        \"mermaid\":   { \"type\": \"string\", \"description\": \"Valid Mermaid diagram source, or empty string when no meaningful diagram can be produced. Renderer shows 'No diagram available' on empty string.\" }\n82\t      }\n83\t    },\n84\t    \"algorithms\": {\n85\t      \"type\": \"object\",\n86\t      \"description\": \"Key algorithms or data-processing patterns used in the project.\",\n87\t      \"required\": [\"technical\", \"layman\", \"entries\"],\n88\t      \"additionalProperties\": false,\n89\t      \"properties\": {\n90\t        \"technical\": { \"type\": \"string\", \"minLength\": 1 },\n91\t        \"layman\":    { \"type\": \"string\", \"minLength\": 1 },\n92\t        \"entries\": {\n93\t          \"type\": \"array\",\n94\t          \"description\": \"May be empty for projects with no notable algorithms.\",\n95\t          \"items\": {\n96\t            \"type\": \"object\",\n97\t            \"required\": [\"name\", \"technical\", \"layman\"],\n98\t            \"additionalProperties\": false,\n99\t            \"properties\": {\n100\t              \"name\":      { \"type\": \"string\", \"minLength\": 1 },\n101\t              \"technical\": { \"type\": \"string\", \"minLength\": 1 },\n102\t              \"layman\":    { \"type\": \"string\", \"minLength\": 1 }\n103\t            }\n104\t          }\n105\t        }\n106\t      }\n107\t    },\n108\t    \"methodologies\": {\n109\t      \"type\": \"object\",\n110\t      \"required\": [\"technical\", \"layman\", \"entries\"],\n111\t      \"additionalProperties\": false,\n112\t