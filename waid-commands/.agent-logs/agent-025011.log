    },\n107\t    {\n108\t      \"id\": \"python\",\n109\t      \"humanName\": \"Python\",\n110\t      \"manifestFiles\": [\n111\t        \"pyproject.toml\",\n112\t        \"setup.py\",\n113\t        \"setup.cfg\",\n114\t        \"requirements.txt\"\n115\t      ],\n116\t      \"keyConfigFiles\": [\n117\t        \"requirements-dev.txt\",\n118\t        \"requirements-test.txt\",\n119\t        \"constraints.txt\",\n120\t        \"tox.ini\",\n121\t        \"pytest.ini\",\n122\t        \".flake8\",\n123\t        \"mypy.ini\",\n124\t        \".mypy.ini\",\n125\t        \"pyproject.toml\",\n126\t        \"ruff.toml\",\n127\t        \".ruff.toml\",\n128\t        \"Pipfile\",\n129\t        \"poetry.lock\",\n130\t        \"uv.lock\",\n131\t        \"conda.yaml\",\n132\t        \"environment.yml\"\n133\t      ],\n134\t      \"entryPointHints\": [\n135\t        \"main.py\",\n136\t        \"app.py\",\n137\t        \"run.py\",\n138\t        \"manage.py\",\n139\t        \"src/main.py\",\n140\t        \"src/app.py\",\n141\t        \"__main__.py\"\n142\t      ],\n143\t      \"workspaceIndicators\": [\"packages/\", \"libs/\", \"services/\"],\n144\t      \"notes\": \"pyproject.toml is the modern standard (PEP 518/621). setup.py and requirements.txt are legacy. Multiple manifest files may coexist in the same project.\"\n145\t    },\n146\t    {\n147\t      \"id\": \"java\",\n148\t      \"humanName\": \"Java / JVM\",\n149\t      \"manifestFiles\": [\"pom.xml\", \"build.gradle\", \"build.gradle.kts\"],\n150\t      \"keyConfigFiles\": [\n151\t        \"settings.gradle\",\n152\t        \"settings.gradle.kts\",\n153\t        \"gradle.properties\",\n154\t        \"gradlew\",\n155\t        \".mvn/wrapper/maven-wrapper.properties\",\n156\t        \"checkstyle.xml\",\n157\t        \"spotbugs.xml\",\n158\t        \"application.properties\",\n159\t        \"application.yml\"\n160\t      ],\n161\t      \"entryPointHints\": [\n162\t        \"src/main/java/**/*Application.java\",\n163\t        \"src/main/java/**/Main.java\",\n164\t        \"src/main/kotlin/**/*Application.kt\"\n165\t      ],\n166\t      \"workspaceIndicators\": [\"settings.gradle\", \"settings.gradle.kts\"],\n167\t      \"notes\": \"pom.xml = Maven; build.gradle(.kts) = Gradle. Kotlin detection: look for .kt files and kotlin plugin in the build file. Spring Boot: spring-boot-starter in dependencies.\"\n168\t    },\n169\t    {\n170\t      \"id\": \"ruby\",\n171\t      \"humanName\": \"Ruby\",\n172\t      \"manifestFiles\": [\"Gemfile\"],\n173\t      \"keyConfigFiles\": [\n174\t        \"Gemfile.lock\",\n175\t        \".ruby-version\",\n176\t        \".rubocop.yml\",\n177\t        \"Rakefile\",\n178\t        \"config/application.rb\",\n179\t        \"config/routes.rb\"\n180\t      ],\n181\t      \"entryPointHints\": [\n182\t        \"app/controllers/application_controller.rb\",\n183\t        \"config.ru\",\n184\t        \"bin/rails\",\n185\t        \"app.rb\"\n186\t      ],\n187\t      \"workspaceIndicators\": [],\n188\t      \"notes\": \"Gemfile presence is definitive. config/application.rb confirms Rails.\"\n189\t    },\n190\t    {\n191\t      \"id\": \"php\",\n192\t      \"humanName\": \"PHP\",\n193\t      \"manifestFiles\": [\"composer.json\"],\n194\t      \"keyConfigFiles\": [\n195\t        \"composer.lock\",\n196\t        \"phpunit.xml\",\n197\t        \"phpunit.xml.dist\",\n198\t        \"phpcs.xml\",\n199\t        \".php-cs-fixer.php\",\n200\t        \"phpstan.neon\",\n201\t        \"psalm.xml\",\n202\t        \"artisan\",\n203\t        \"webpack.mix.js\",\n204\t        \"vite.config.js\"\n205\t      ],\n206\t      \"entryPointHints\": [\n207\t        \"public/index.php\",\n208\t        \"index.php\",\n209\t        \"bootstrap/app.php\",\n210\t        \"src/index.php\"\n211\t      ],\n212\t      \"workspaceIndicators\": [],\n213\t      \"notes\": \"artisan file confirms Laravel. composer.json with symfony/* dependencies confirms Symfony.\"\n214\t    },\n215\t    {\n216\t      \"id\": \"dotnet\",\n217\t      \"humanName\": \".NET / C#\",\n218\t      \"manifestFiles\": [\"*.csproj\", \"*.fsproj\", \"*.vbproj\", \"global.json\"],\n219\t      \"manifestFilesAreGlobs\": true,\n220\t      \"keyConfigFiles\": [\n221\t        \"Directory.Build.props\",\n222\t        \"Directory.Build.targets\",\n223\t        \"NuGet.Config\",\n224\t        \"nuget.config\",\n225\t        \".editorconfig\",\n226\t        \"appsettings.json\",\n227\t        \"appsettings.Development.json\",\n228\t        \"launchSettings.json\"\n229\t      ],\n230\t      \"entryPointHints\": [\n231\t        \"Program.cs\",\n232\t        \"Startup.cs\",\n233\t        \"src/**/Program.cs\"\n234\t      ],\n235\t      \"workspaceIndicators\": [\"*.sln\"],\n236\t      \"notes\": \"*.csproj glob requires the slash command to use file-extension matching, not exact filename. *.sln indicates a Visual Studio solution with multiple projects.\"\n237\t    },\n238\t    {\n239\t      \"id\": \"swift\",\n240\t      \"humanName\": \"Swift / Apple Platforms\",\n241\t      \"manifestFiles\": [\"Package.swift\"],\n242\t      \"keyConfigFiles\": [\n243\t        \"Package.resolved\",\n244\t        \".swiftformat\",\n245\t        \".swiftlint.yml\",\n246\t        \"Podfile\",\n247\t        \"Cartfile\",\n248\t        \"project.pbxproj\"\n249\t      ],\n250\t      \"entryPointHints\": [\n251\t        \"Sources/**/main.swift\",\n252\t        \"Sources/**/*App.swift\",\n\n... [29 lines truncated] ..."},"type":"attachment","uuid":"e1727493-e638-4294-821f-203babecd847","timestamp":"2026-05-02T06:47:09.510Z","userType":"external","entrypoint":"cli","cwd":"/Users/avinkrism4pro/Personal/apps/MyApps/whatAmIDoing/waid-commands","sessionId":"72a03414-ba52-4106-b27a-7f28ae50fe45","version":"2.1.126","gitBranch":"main"}
{"parentUuid":"e1727493-e638-4294-821f-203babecd847","isSidechain":false,"attachment":{"type":"edited_text_file","filename":"/Users/avinkrism4pro/Personal/apps/MyApps/whatAmIDoing/waid-commands/assets/template.css","snippet":"1\t/* === DESIGN TOKENS THEME - DesignTokens Contract Implementation ===\n2\t   All CSS custom properties and component styles per .framework/contracts/theme/DesignTokens.contract.md\n3\t   Light mode defaults in :root, dark mode overrides in [data-theme=\"dark\"],\n4\t   auto mode in [data-theme=\"auto\"] with @media (prefers-color-scheme: dark).\n5\t   Reduced motion override in @media (prefers-reduced-motion: reduce).\n6\t*/\n7\t\n8\t/* === COLOR TOKENS (Light Mode Defaults) ===\n9\t   32 color tokens across background, text, accent, severity, code, chip, toggle, focus, quiz families.\n10\t*/\n11\t:root {\n12\t  /* Background tokens */\n13\t  --waid-color-bg-base: #fefefe;\n14\t  --waid-color-bg-surface: #f5f6f8;\n15\t  --waid-color-bg-sunken: #eceef2;\n16\t  --waid-color-bg-overlay: #ffffff;\n17\t\n18\t  /* Border tokens */\n19\t  --waid-color-border: #dde1e7;\n20\t  --waid-color-border-subtle: #eceef2;\n21\t\n22\t  /* Text tokens */\n23\t  --waid-color-text-primary: #111318;\n24\t  --waid-color-text-secondary: #4a5260;\n25\t  --waid-color-text-tertiary: #7a8499;\n26\t  --waid-color-text-inverse: #ffffff;\n27\t  --waid-color-text-code: #1a2a44;\n28\t\n29\t  /* Accent tokens */\n30\t  --waid-color-accent: #3b72f2;\n31\t  --waid-color-accent-subtle: #eef2fe;\n32\t  --waid-color-accent-muted: #7da0f8;\n33\t\n34\t  /* Code tokens */\n35\t  --waid-color-code-bg: #1e2330;\n36\t  --waid-color-code-border: #2d3348;\n37\t\n38\t  /* Severity tokens - Low */\n39\t  --waid-color-severity-low: #1e7a4f;\n40\t  --waid-color-severity-low-bg: #edfaf3;\n41\t  --waid-color-severity-low-border: #a3dfc0;\n42\t\n43\t  /* Severity tokens - Medium */\n44\t  --waid-color-severity-medium: #92620a;\n45\t  --waid-color-severity-medium-bg: #fef9ec;\n46\t  --waid-color-severity-medium-border: #f5d48a;\n47\t\n48\t  /* Severity tokens - High */\n49\t  --waid-color-severity-high: #b02020;\n50\t  --waid-color-severity-high-bg: #fff0f0;\n51\t  --waid-color-severity-high-border: #f5baba;\n52\t\n53\t  /* Chip tokens */\n54\t  --waid-color-chip-bg: #eceef2;\n55\t  --waid-color-chip-text: #2e3442;\n56\t  --waid-color-chip-border: #dde1e7;\n57\t\n58\t  /* Toggle tokens */\n59\t  --waid-color-toggle-bg: #dde1e7;\n60\t  --waid-color-toggle-thumb: #ffffff;\n61\t\n62\t  /* Focus and Quiz tokens */\n63\t  --waid-color-focus-ring: #3b72f2;\n64\t  --waid-color-quiz-correct: #1e7a4f;\n65\t  --waid-color-quiz-incorrect: #b02020;\n66\t\n67\t  /* === TYPOGRAPHY TOKENS ===\n68\t     2 font families, 8 size scale (1.2 ratio, base 16px),\n69\t     4 weights, 4 line heights, 3 letter spacings.\n70\t  */\n71\t\n72\t  /* Font families */\n73\t  --waid-font-sans: \"Inter\", system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif;\n74\t  --waid-font-mono: \"JetBrains Mono\", \"Fira Code\", Menlo, Consolas, \"Courier New\", monospace;\n75\t\n76\t  /* Font size scale - 1.2 ratio */\n77\t  --waid-fs-xs: 0.6875rem;\n78\t  --waid-fs-sm: 0.8125rem;\n79\t  --waid-fs-base: 1rem;\n80\t  --waid-fs-md: 1.1875rem;\n81\t  --waid-fs-lg: 1.4375rem;\n82\t  --waid-fs-xl: 1.75rem;\n83\t  --waid-fs-2xl: 2.0625rem;\n84\t  --waid-fs-3xl: 2.5rem;\n85\t\n86\t  /* Font weights */\n87\t  --waid-fw-regular: 400;\n88\t  --waid-fw-medium: 500;\n89\t  --waid-fw-semibold: 600;\n90\t  --waid-fw-bold: 700;\n91\t\n92\t  /* Line heights */\n93\t  --waid-lh-tight: 1.25;\n94\t  --waid-lh-snug: 1.4;\n95\t  --waid-lh-body: 1.6;\n96\t  --waid-lh-code: 1.55;\n97\t\n98\t  /* Letter spacing */\n99\t  --waid-ls-tight: -0.01em;\n100\t  --waid-ls-normal: 0em;\n101\t  --waid-ls-wide: 0.04em;\n102\t\n103\t  /* === SPACING TOKENS ===\n104\t     4px-based grid from 4px to 64px.\n105\t  */\n106\t  --waid-space-1: 4px;\n107\t  --waid-space-2: 8px;\n108\t  --waid-space-3: 12px;\n109\t  --waid-space-4: 16px;\n110\t  --waid-space-6: 24px;\n111\t  --waid-space-8: 32px;\n112\t  --waid-space-12: 48px;\n113\t  --waid-space-16: 64px;\n114\t\n115\t  /* === LAYOUT TOKENS === */\n116\t  --waid-content-max-width: 880px;\n117\t  --waid-toc-width: 260px;\n118\t\n119\t  /* === Z-INDEX TOKENS === */\n120\t  --waid-z-header: 100;\n121\t  --waid-z-toc: 90;\n122\t  --waid-z-tooltip: 200;\n123\t  --waid-z-dialog: 300;\n124\t\n125\t  /* === RADIUS TOKENS === */\n126\t  --waid-radius-sm: 4px;\n127\t  --waid-radius-md: 8px;\n128\t  --waid-radius-lg: 12px;\n129\t  --waid-radius-xl: 16px;\n130\t  --waid-radius-full: 9999px;\n131\t  --waid-radius-pill: 9999px;\n132\t\n133\t  /* === SHADOW TOKENS ===\n134\t     Light mode shadows with dark mode overrides below.\n135\t  */\n136\t  --waid-shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.06);\n137\t  --waid-shadow-sm: 0 2px 6px rgba(0, 0, 0, 0.08);\n138\t  --waid-shadow-md: 0 4px 16px rgba(0, 0, 0, 0.10);\n139\t  --waid-shadow-lg: 0 12px 32px rgba(0, 0, 0, 0.14);\n140\t  --waid-shadow-focus: 0 0 0 3px rgba(59, 114, 242, 0.35);\n141\t\n142\t  /* Semantic shadow aliases */\n143\t  --waid-shadow-card: var(--waid-shadow-sm);\n144\t  --waid-shadow-tooltip: var(--waid-shadow-md);\n145\t  --waid-shadow-dialog: var(--waid-shadow-lg);\n146\t\n147\t  /* === MOTION TOKENS === */\n148\t  --waid-duration-instant: 80ms;\n149\t  --waid-duration-fast: 150ms;\n150\t  --waid-duration-medium: 240ms;\n151\t  --waid-duration-normal: var(--waid-duration-medium);\n152\t  --waid-duration-slow: 400ms;\n153\t\n154\t  --waid-ease-default: cubic-bezier(0.4, 0, 0.2, 1);\n155\t  --waid-ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);\n156\t}\n157\t\n158\t/* === DARK MODE OVERRIDES ===\n159\t   Applied when data-theme=\"dark\" on <html>.\n160\t*/\n161\t[data-theme=\"dark\"] {\n162\t  /* Background tokens */\n163\t  --waid-color-bg-base: #0e1014;\n164\t  --waid-color-bg-surface: #14171d;\n165\t  --waid-color-bg-sunken: #0b0d10;\n166\t  --waid-color-bg-overlay: #1c2029;\n167\t\n168\t  /* Border tokens */\n169\t  --waid-color-border: #2a2f3a;\n170\t  --waid-color-border-subtle: #1e2229;\n171\t\n172\t  /* Text tokens */\n173\t  --waid-color-text-primary: #e8eaf0;\n174\t  --waid-color-text-secondary: #8b93a4;\n175\t  --waid-color-text-tertiary: #5c6475;\n176\t  --waid-color-text-inverse: #111318;\n177\t  --waid-color-text-code: #c9d8f0;\n178\t\n179\t  /* Accent tokens */\n180\t  --waid-color-accent: #5d8fff;\n181\t  --waid-color-accent-subtle: #1a2545;\n182\t  --waid-color-accent-muted: #3b5db8;\n183\t\n184\t  /* Code tokens */\n185\t  --waid-color-code-bg: #101318;\n186\t  --waid-color-code-border: #1e2330;\n187\t\n188\t  /* Severity tokens - Low */\n189\t  --waid-color-severity-low: #34c47a;\n190\t  --waid-color-severity-low-bg: #0d2a1c;\n191\t  --waid-color-severity-low-border: #1a4a32;\n192\t\n193\t  /* Severity tokens - Medium */\n194\t  --waid-color-severity-medium: #f0b94a;\n195\t  --waid-color-severity-medium-bg: #2a1e08;\n196\t  --waid-color-severity-medium-border: #4a3410;\n197\t\n198\t  /* Severity tokens - High */\n199\t  --waid-color-severity-high: #f27272;\n200\t  --waid-color-severity-high-bg: #2a0e0e;\n201\t  --waid-color-severity-high-border: #4a1818;\n202\t\n203\t  /* Chip tokens */\n204\t  --waid-color-chip-bg: #1c2029;\n205\t  --waid-color-chip-text: #b0b8cc;\n206\t  --waid-color-chip-border: #2a2f3a;\n207\t\n208\t  /* Toggle tokens */\n209\t  --waid-color-toggle-bg: #2a2f3a;\n210\t  --waid-color-toggle-thumb: #e8eaf0;\n211\t\n212\t  /* Focus and Quiz tokens */\n213\t  --waid-color-focus-ring: #5d8fff;\n214\t  --waid-color-quiz-correct: #34c47a;\n215\t  --waid-color-quiz-incorrect: #f27272;\n216\t\n217\t  /* Dark mode shadow tokens */\n218\t  --waid-shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.3);\n219\t  --waid-shadow-sm: 0 2px 6px rgba(0, 0, 0, 0.4);\n220\t  --waid-shadow-md: 0 4px 16px rgba(0, 0, 0, 0.5);\n221\t  --waid-shadow-lg: 0 12px 32px rgba(0, 0, 0, 0.6);\n222\t  --waid-shadow-focus: 0 0 0 3px rgba(93, 143, 255, 0.4);\n223\t}\n224\t\n225\t/* === AUTO MODE (Respects System Preference) ===\n226\t   When data-theme=\"auto\", dark mode overrides apply inside prefers-color-scheme media query.\n227\t*/\n228\t[data-theme=\"auto\"] {\n229\t  @media (prefers-color-scheme: dark) {\n230\t    /* Background tokens */\n231\t    --waid-color-bg-base: #0e1014;\n232\t    --waid-color-bg-surface: #14171d;\n233\t    --waid-color-bg-sunken: #0b0d10;\n234\t    --waid-color-bg-overlay: #1c2029;\n235\t\n236\t    /* Border tokens */\n237\t    --waid-color-border: #2a2f3a;\n238\t    --waid-color-border-subtle: #1e2229;\n239\t\n240\t    /* Text tokens */\n241\t    --waid-color-text-primary: #e8eaf0;\n242\t    --waid-color-text-secondary: #8b93a4;\n243\t    --waid-color-text-tertiary: #5c6475;\n244\t    --waid-color-text-inverse: #111318;\n245\t    --waid-color-text-code: #c9d8f0;\n246\t\n247\t    /* Accent tokens */\n248\t    --waid-color-accent: #5d8fff;\n\n... [613 lines truncated] ..."},"type":"attachment","uuid":"fdce357b-95df-4724-bee7-33636ba06f2a","timestamp":"2026-05-02T06:47:09.510Z","userType":"external","entrypoint":"cli","cwd":"/Users/avinkrism4pro/Personal/apps/MyApps/whatAmIDoing/waid-commands","sessionId":"72a03414-ba52-4106-b27a-7f28ae50fe45","version":"2.1.126","gitBranch":"main"}
