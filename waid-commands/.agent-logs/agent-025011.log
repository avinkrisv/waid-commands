me}\n  #       props:\n  #         {prop_name}: \"{state_source.field}\"\n  #       callbacks:\n  #         {callback_name}: \"{provider.method(args)}\"\n  #       visible_when: \"{condition or 'always'}\"\n\n# State wiring: which providers are initialized at app level vs screen level\nproviders:\n  # - name: {providerName}\n  #   component: {ComponentName}\n  #   scope: {app|screen}\n\n# Background services (sync engines, notification scheduling, etc.)\nservices:\n  # - name: {serviceName}\n  #   component: {ComponentName}\n  #   starts_at: {app_init|screen_enter}\n\n# Assembly order — simplest wiring to most complex\n# The assembler works through this list sequentially\nassembly_order:\n  # - theme\n  # - {simple_read_only_screen}\n  # - {crud_screen}\n  # - {complex_interactive_screen}\n  # - navigation_shell\n  # - infrastructure","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false},"sourceToolAssistantUUID":"7c47d782-7091-4d40-b43c-63754f28e10f","userType":"external","entrypoint":"cli","cwd":"/Users/avinkrism4pro/Personal/apps/MyApps/whatAmIDoing","sessionId":"72a03414-ba52-4106-b27a-7f28ae50fe45","version":"2.1.126","gitBranch":"main"}
